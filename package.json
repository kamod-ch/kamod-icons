{
  "name": "kamod-icons",
  "version": "1.0.0",
  "description": "ightweight, tree-shakeable SVG icon library for Preact, Kamod UI and modern frontend apps.",
  "keywords": [
    "preact",
    "icons",
    "svg-icons",
    "icon-library",
    "typescript",
    "tree-shaking",
    "tree-shakeable",
    "preact-components",
    "ui-components",
    "design-system",
    "kamod-ui",
    "kamod-icons",
    "preactpress",
    "figma-icons",
    "npm-package",
    "monorepo",
    "frontend",
    "webdev",
    "developer-tools",
    "shadcn"
  ],
  "homepage": "https://kamod-ch.github.io/kamod-icons/",
  "bugs": {
    "url": "https://github.com/kamod-ch/kamod-icons/issues"
  },
  "license": "MIT",
  "author": "Klaus Zahiragic <watzak>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kamod-ch/kamod-icons.git"
  },
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "icons:sync": "pnpm --filter @kamod/icons icons:sync",
    "icons:generate": "pnpm --filter @kamod/icons icons:generate",
    "build:icons": "pnpm --filter @kamod/icons build",
    "build:docs": "pnpm --filter @kamod/icons-docs build",
    "build": "pnpm run build:icons && pnpm run build:docs",
    "dev:icons": "pnpm --filter @kamod/icons dev",
    "dev:docs": "pnpm --filter @kamod/icons-docs dev",
    "check:docs": "pnpm --filter @kamod/icons-docs check",
    "preview:docs": "pnpm --filter @kamod/icons-docs preview",
    "clean": "pnpm --filter @kamod/icons clean && rm -rf docs/dist"
  }
}

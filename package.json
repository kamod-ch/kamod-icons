{
  "name": "kamod-icons",
  "version": "1.0.0",
  "private": true,
  "description": "Lightweight, tree-shakeable SVG icon library for Preact apps.",
  "keywords": [
    "preact",
    "icons",
    "svg-icons",
    "icon-library",
    "typescript",
    "tree-shaking",
    "tree-shakeable",
    "preact-components",
    "ui-components",
    "design-system",
    "kamod-ui",
    "kamod-icons",
    "preactpress",
    "figma-icons",
    "npm-package",
    "monorepo",
    "frontend",
    "webdev",
    "developer-tools",
    "shadcn"
  ],
  "homepage": "https://kamod-ch.github.io/kamod-icons/",
  "bugs": {
    "url": "https://github.com/kamod-ch/kamod-icons/issues"
  },
  "license": "MIT",
  "author": "Klaus Zahiragic <watzak>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kamod-ch/kamod-icons.git"
  },
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepublishOnly": "node -e \"console.error('Do not publish the workspace root. Use: pnpm publish:core'); process.exit(1)\"",
    "icons:sync": "pnpm --filter @kamod-ch/icons icons:sync",
    "icons:generate": "pnpm --filter @kamod-ch/icons icons:generate",
    "build:icons": "pnpm --filter @kamod-ch/icons build",
    "build:docs": "pnpm --filter @kamod-ch/icons-docs build",
    "build": "pnpm run build:icons && pnpm run build:docs",
    "dev:icons": "pnpm --filter @kamod-ch/icons dev",
    "docs:dev": "pnpm --filter @kamod-ch/icons-docs dev",
    "check:docs": "pnpm --filter @kamod-ch/icons-docs check",
    "docs:preview": "pnpm --filter @kamod-ch/icons-docs preview",
    "clean": "pnpm --filter @kamod-ch/icons clean && rm -rf packages/docs/dist",
    "pack:core": "pnpm --filter @kamod-ch/icons exec npm pack --dry-run",
    "publish:core": "pnpm --filter @kamod-ch/icons publish --access public",
    "release": "node ./scripts/release.mjs patch",
    "release:minor": "node ./scripts/release.mjs minor",
    "release:major": "node ./scripts/release.mjs major",
    "release:dry": "node ./scripts/release.mjs patch --dry"
  }
}
